# ===== Obsidian Vault =====
# Шлях до папки вашого Obsidian vault (де зберігаються нотатки про ЖК, опалення тощо)
# Приклади:
#   Mac/Linux: OBSIDIAN_VAULT_PATH=/Users/yourname/Documents/MyVault
#   Windows:   OBSIDIAN_VAULT_PATH=C:\Users\yourname\Documents\MyVault
# Якщо не задано — бот використовує локальну папку ./memory-vault
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# ===== Supabase (for upload.js) =====
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_TABLE=apartments
OUTPUT_DATA_FILE=data-lun.json

# ===== Firebase (example only, if you use Firebase elsewhere) =====
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef123456
